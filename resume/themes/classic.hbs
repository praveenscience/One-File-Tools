<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{displayName}} — Resume</title>
<style>
@page { size: A4; margin: 15mm 20mm; }

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 10.5pt;
  line-height: 1.5;
  color: #1a1a1a;
  background: #f5f5f5;
}

.page {
  max-width: 210mm;
  margin: 2rem auto;
  background: #fff;
  padding: 40px 48px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.1);
}

/* Header */
header { text-align: center; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 2px solid #2563eb; }
h1 { font-size: 22pt; font-weight: 700; color: #111; letter-spacing: -0.02em; margin-bottom: 2px; }
.title { font-size: 11pt; color: #2563eb; font-weight: 500; margin-bottom: 8px; }
.contact-line { font-size: 9pt; color: #555; display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 16px; }
.contact-line a { color: #2563eb; text-decoration: none; }

/* Sections */
section { margin-bottom: 18px; }
h2 {
  font-size: 11pt; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em; color: #2563eb;
  border-bottom: 1px solid #d1d5db; padding-bottom: 3px; margin-bottom: 10px;
}
h3 { font-size: 10.5pt; font-weight: 600; color: #111; }
.description { font-size: 10pt; color: #333; margin-bottom: 4px; }
ul { padding-left: 18px; margin-bottom: 8px; }
li { font-size: 10pt; color: #333; margin-bottom: 2px; }

/* Entries (experience, education, volunteer) */
.entry { margin-bottom: 14px; }
.entry-header { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 4px; }
.entry-header h3 { flex: 1; }
.entry-header .dates { font-size: 9pt; color: #666; white-space: nowrap; }
.company { font-size: 10pt; color: #444; font-weight: 500; }

/* Skills */
.skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px; }
.skill-group { margin-bottom: 6px; }
.skill-group h3 { font-size: 9.5pt; color: #2563eb; font-weight: 600; margin-bottom: 2px; }
.skill-list { font-size: 10pt; color: #333; }

/* Certifications */
.cert-item { margin-bottom: 6px; }
.cert-name { font-weight: 600; font-size: 10pt; }
.cert-meta { font-size: 9pt; color: #666; }

/* Languages */
.lang-list { display: flex; gap: 16px; flex-wrap: wrap; font-size: 10pt; }
.lang-name { font-weight: 600; }
.lang-level { color: #666; font-size: 9pt; }

/* Publications */
.pub-item { margin-bottom: 6px; font-size: 10pt; }
.pub-item a { color: #2563eb; text-decoration: none; }
.pub-meta { font-size: 9pt; color: #666; }

/* Awards */
.award-item { margin-bottom: 6px; }
.award-name { font-weight: 600; font-size: 10pt; }
.award-meta { font-size: 9pt; color: #666; }

/* Testimonials */
.testimonial { margin-bottom: 12px; padding: 10px 14px; border-left: 3px solid #2563eb; background: #f8fafc; }
.testimonial blockquote { font-size: 10pt; color: #333; font-style: italic; margin-bottom: 4px; }
.testimonial cite { font-size: 9pt; color: #666; font-style: normal; }

/* Interests */
.interests-list { display: flex; gap: 8px; flex-wrap: wrap; }
.interest-tag { font-size: 9pt; padding: 3px 10px; border-radius: 999px; background: #eff6ff; color: #2563eb; font-weight: 500; }

/* Responsive */
@media screen and (max-width: 700px) {
  .page { margin: 0; padding: 24px 20px; box-shadow: none; }
  .skills-grid { grid-template-columns: 1fr; }
  .entry-header { flex-direction: column; }
}

/* Print */
@media print {
  body { background: #fff; font-size: 10pt; }
  .page { margin: 0; padding: 0; box-shadow: none; max-width: none; }
  a { color: #000; text-decoration: none; }
  header { border-bottom-color: #000; }
  h2 { color: #000; border-bottom-color: #999; }
  .title { color: #333; }
  .contact-line a { color: #333; }
  h2 { break-after: avoid; }
  .entry { break-inside: avoid; }
  section { break-inside: avoid; }
  .testimonial { background: #f8f8f8; }
}
</style>
</head>
<body>
<div class="page">

<header>
  <h1>{{displayName}}</h1>
  {{#title}}<div class="title">{{title}}</div>{{/title}}
  <div class="contact-line">
    {{#email}}<a href="mailto:{{email}}">{{email}}</a>{{/email}}
    {{#phone}}<span>{{phone}}</span>{{/phone}}
    {{#website}}<a href="{{website}}">{{website}}</a>{{/website}}
    {{#socialLinks}}<a href="{{url}}">{{label}}</a>{{/socialLinks}}
    {{#locationStr}}<span>{{locationStr}}</span>{{/locationStr}}
  </div>
</header>

{{#summary}}
<section>
  <h2>Summary</h2>
  <p class="description">{{summary}}</p>
</section>
{{/summary}}

{{#has experience}}
<section>
  <h2>Experience</h2>
  {{#experience}}
  <div class="entry">
    <div class="entry-header">
      <h3>{{role}}</h3>
      <span class="dates">{{fmtDate startDate}} — {{fmtDate endDate}}</span>
    </div>
    <div class="company">{{company}}{{#location}} | {{location}}{{/location}}</div>
    {{#description}}<p class="description">{{description}}</p>{{/description}}
    {{#has highlights}}
    <ul>
      {{#highlights}}<li>{{.}}</li>{{/highlights}}
    </ul>
    {{/has}}
  </div>
  {{/experience}}
</section>
{{/has}}

{{#has education}}
<section>
  <h2>Education</h2>
  {{#education}}
  <div class="entry">
    <div class="entry-header">
      <h3>{{degree}}{{#field}} in {{field}}{{/field}}</h3>
      <span class="dates">{{fmtDate startDate}} — {{fmtDate endDate}}</span>
    </div>
    <div class="company">{{institution}}{{#gpa}} | GPA: {{gpa}}{{/gpa}}</div>
    {{#has honors}}
    <ul>
      {{#honors}}<li>{{.}}</li>{{/honors}}
    </ul>
    {{/has}}
  </div>
  {{/education}}
</section>
{{/has}}

{{#has skills}}
<section>
  <h2>Skills</h2>
  <div class="skills-grid">
    {{#skills}}
    <div class="skill-group">
      <h3>{{category}}</h3>
      <div class="skill-list">{{#items}}{{name}}{{^@last}}, {{/@last}}{{/items}}</div>
    </div>
    {{/skills}}
  </div>
</section>
{{/has}}

{{#has projects}}
<section>
  <h2>Projects</h2>
  {{#projects}}
  <div class="entry">
    <div class="entry-header">
      <h3>{{name}}{{#tagline}} — {{tagline}}{{/tagline}}</h3>
      {{#year}}<span class="dates">{{year}}</span>{{/year}}
    </div>
    {{#description}}<p class="description">{{description}}</p>{{/description}}
    {{#has highlights}}
    <ul>
      {{#highlights}}<li>{{.}}</li>{{/highlights}}
    </ul>
    {{/has}}
  </div>
  {{/projects}}
</section>
{{/has}}

{{#has certifications}}
<section>
  <h2>Certifications</h2>
  {{#certifications}}
  <div class="cert-item">
    <span class="cert-name">{{name}}</span>
    <span class="cert-meta"> — {{issuer}}, {{fmtDate date}}</span>
  </div>
  {{/certifications}}
</section>
{{/has}}

{{#has publications}}
<section>
  <h2>Publications</h2>
  {{#publications}}
  <div class="pub-item">
    {{#url}}<a href="{{url}}">{{title}}</a>{{/url}}
    {{^url}}{{title}}{{/url}}
    <span class="pub-meta"> — {{publisher}}, {{fmtDate date}}</span>
  </div>
  {{/publications}}
</section>
{{/has}}

{{#has languages}}
<section>
  <h2>Languages</h2>
  <div class="lang-list">
    {{#languages}}<span><span class="lang-name">{{language}}</span> <span class="lang-level">({{proficiency}})</span></span>{{/languages}}
  </div>
</section>
{{/has}}

{{#has volunteer}}
<section>
  <h2>Volunteer</h2>
  {{#volunteer}}
  <div class="entry">
    <div class="entry-header">
      <h3>{{role}}</h3>
      <span class="dates">{{fmtDate startDate}} — {{fmtDate endDate}}</span>
    </div>
    <div class="company">{{organization}}</div>
    {{#description}}<p class="description">{{description}}</p>{{/description}}
  </div>
  {{/volunteer}}
</section>
{{/has}}

{{#has awards}}
<section>
  <h2>Awards</h2>
  {{#awards}}
  <div class="award-item">
    <span class="award-name">{{title}}</span>
    <span class="award-meta"> — {{issuer}}, {{fmtDate date}}</span>
    {{#description}}<div class="description">{{description}}</div>{{/description}}
  </div>
  {{/awards}}
</section>
{{/has}}

{{#has testimonials}}
<section>
  <h2>Testimonials</h2>
  {{#testimonials}}
  <div class="testimonial">
    <blockquote>"{{quote}}"</blockquote>
    <cite>— {{author}}{{#if role}}, {{role}}{{/if}}{{#if company}} at {{company}}{{/if}}</cite>
  </div>
  {{/testimonials}}
</section>
{{/has}}

{{#has interests}}
<section>
  <h2>Interests</h2>
  <div class="interests-list">
    {{#interests}}<span class="interest-tag">{{.}}</span>{{/interests}}
  </div>
</section>
{{/has}}

</div>
<footer style="text-align:center;padding:1.5rem;font-size:8pt;color:#999;border-top:1px solid #e5e7eb;margin-top:1rem">
  <p>Built with <a href="{{toolsUrl}}" style="color:#2563eb;text-decoration:none">One File Tools</a></p>
</footer>
</body>
</html>
