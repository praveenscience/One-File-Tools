{{!
  portfolio.hbs — renders entirely from profile.json
  ─────────────────────────────────────────────────
  Required helpers (registered in build.js):
    dotDate  "2022-03" → "2022.03"
    lower    lowercase a string
    initials "John Smith" → "JS"
    tel      "+1-555-0123" → "+15550123"
    json     JSON.stringify(ctx, null, 2), script-safe
    year     current year
    cycle    (index, ...values) → values[index % values.length]
  Context extras (computed in build.js):
    log      talks + publications + certifications + awards,
             merged and sorted newest-first
}}

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{personal.displayName}} — {{personal.title}}</title>
    <meta name="description" content="{{personal.headline}}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      /* ============================================================
   THEME — the whole page is a syntax theme.
   violet = keys · mint = strings · amber = numbers
   ============================================================ */
      :root {
        --ink: #0a0c15;
        --panel: #11141f;
        --panel-2: #151927;
        --line: rgba(237, 239, 246, 0.08);
        --line-strong: rgba(237, 239, 246, 0.14);
        --paper: #edeff6;
        --fog: #99a0b5;
        --dim: #5e6478;
        --violet: #9d8cff;
        --violet-soft: rgba(157, 140, 255, 0.13);
        --mint: #6fe3be;
        --mint-soft: rgba(111, 227, 190, 0.12);
        --amber: #ffb474;
        --amber-soft: rgba(255, 180, 116, 0.12);
        --display: "Bricolage Grotesque", system-ui, sans-serif;
        --body: "Instrument Sans", system-ui, sans-serif;
        --mono: "JetBrains Mono", ui-monospace, monospace;
        --max: 1080px;
        --ease: cubic-bezier(0.22, 1, 0.36, 1);
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 84px;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.001s !important;
          transition-duration: 0.001s !important;
        }
      }
      body {
        background: var(--ink);
        color: var(--paper);
        font-family: var(--body);
        font-size: 16px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      ::selection {
        background: var(--violet);
        color: var(--ink);
      }
      a {
        color: var(--mint);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      :focus-visible {
        outline: 2px solid var(--violet);
        outline-offset: 3px;
        border-radius: 2px;
      }
      .wrap {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 28px;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image: radial-gradient(rgba(237, 239, 246, 0.045) 1px, transparent 1px);
        background-size: 26px 26px;
      }
      main,
      header.site,
      footer.site {
        position: relative;
        z-index: 1;
      }

      /* ===================== NAV ===================== */
      header.site {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: rgba(10, 12, 21, 0.78);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--line);
      }
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        font-family: var(--mono);
        font-size: 14px;
        font-weight: 600;
        color: var(--paper);
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand .v {
        color: var(--violet);
      }
      .brand .m {
        color: var(--mint);
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 26px;
        list-style: none;
      }
      .nav-links a {
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--fog);
        letter-spacing: 0.02em;
      }
      .nav-links a:hover {
        color: var(--paper);
        text-decoration: none;
      }
      .src-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--mono);
        font-size: 12.5px;
        font-weight: 500;
        color: var(--violet);
        background: var(--violet-soft);
        border: 1px solid rgba(157, 140, 255, 0.35);
        border-radius: 8px;
        padding: 7px 13px;
        cursor: pointer;
        transition:
          background 0.2s var(--ease),
          transform 0.2s var(--ease);
      }
      .src-btn:hover {
        background: rgba(157, 140, 255, 0.22);
        transform: translateY(-1px);
      }
      .src-btn kbd {
        font-family: var(--mono);
        font-size: 10.5px;
        color: var(--fog);
        border: 1px solid var(--line-strong);
        border-radius: 4px;
        padding: 1px 5px;
        background: var(--panel);
      }
      @media (max-width: 720px) {
        .nav-links {
          display: none;
        }
      }

      /* ===================== HERO ===================== */
      .hero {
        padding: 172px 0 110px;
      }
      .hero-path {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--dim);
        margin-bottom: 26px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px 18px;
        align-items: center;
      }
      .hero-path .ver {
        color: var(--amber);
      }
      .hero h1 {
        font-family: var(--display);
        font-size: clamp(56px, 9.5vw, 116px);
        font-weight: 800;
        line-height: 0.98;
        letter-spacing: -0.025em;
        margin-bottom: 26px;
      }
      .hero h1 .cursor {
        display: inline-block;
        width: 0.09em;
        height: 0.82em;
        background: var(--mint);
        vertical-align: baseline;
        margin-left: 0.06em;
        transform: translateY(0.08em);
        animation: blink 1.1s steps(1) infinite;
      }
      @keyframes blink {
        50% {
          opacity: 0;
        }
      }
      .hero .headline {
        font-family: var(--display);
        font-weight: 600;
        font-size: clamp(20px, 3vw, 28px);
        letter-spacing: -0.01em;
        color: var(--violet);
        max-width: 640px;
        margin-bottom: 22px;
      }
      .hero .bio {
        max-width: 600px;
        color: var(--fog);
        font-size: 17px;
        margin-bottom: 36px;
      }
      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 40px;
      }
      .chip {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--fog);
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        padding: 6px 14px;
        background: var(--panel);
      }
      .chip.live {
        color: var(--mint);
        border-color: rgba(111, 227, 190, 0.35);
        background: var(--mint-soft);
      }
      .chip.live::before {
        content: "";
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--mint);
        margin-right: 8px;
        box-shadow: 0 0 0 0 rgba(111, 227, 190, 0.5);
        animation: pulse 2.2s infinite;
        vertical-align: 1px;
      }
      @keyframes pulse {
        70% {
          box-shadow: 0 0 0 7px rgba(111, 227, 190, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(111, 227, 190, 0);
        }
      }
      .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }
      .btn {
        font-family: var(--mono);
        font-size: 13.5px;
        font-weight: 600;
        border-radius: 10px;
        padding: 13px 24px;
        display: inline-flex;
        align-items: center;
        gap: 9px;
        cursor: pointer;
        transition:
          transform 0.2s var(--ease),
          box-shadow 0.2s var(--ease),
          background 0.2s var(--ease);
      }
      .btn:hover {
        text-decoration: none;
        transform: translateY(-2px);
      }
      .btn-primary {
        background: var(--violet);
        color: var(--ink);
      }
      .btn-primary:hover {
        box-shadow: 0 8px 28px rgba(157, 140, 255, 0.35);
      }
      .btn-ghost {
        color: var(--paper);
        border: 1px solid var(--line-strong);
        background: transparent;
      }
      .btn-ghost:hover {
        background: var(--panel);
      }

      /* ============ SECTION FRAME — real JSON keys ============ */
      section {
        padding: 52px 0;
      }
      .key-open,
      .key-close {
        font-family: var(--mono);
        font-size: 14px;
      }
      .key-open {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin-bottom: 14px;
      }
      .key-open .k {
        color: var(--violet);
      }
      .key-open .p {
        color: var(--dim);
      }
      .key-open .rule {
        flex: 1;
        height: 1px;
        background: var(--line);
        align-self: center;
      }
      .key-open .count {
        color: var(--dim);
        font-size: 12px;
      }
      .key-close {
        color: var(--dim);
        margin-top: 26px;
      }
      .sec-title {
        font-family: var(--display);
        font-weight: 700;
        letter-spacing: -0.02em;
        font-size: clamp(30px, 4.5vw, 44px);
        margin: 6px 0 40px;
      }

      /* ===================== SKILLS ===================== */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 16px;
      }
      .skill-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 24px;
        transition:
          border-color 0.25s var(--ease),
          transform 0.25s var(--ease);
      }
      .skill-card:hover {
        border-color: rgba(157, 140, 255, 0.4);
        transform: translateY(-3px);
      }
      .skill-card h3 {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 600;
        color: var(--amber);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 18px;
      }
      .skill-card ul {
        list-style: none;
        display: grid;
        gap: 12px;
      }
      .skill-card li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        font-size: 14.5px;
        color: var(--paper);
      }
      .lvl {
        display: inline-flex;
        gap: 4px;
        flex-shrink: 0;
      }
      .lvl i {
        width: 14px;
        height: 4px;
        border-radius: 2px;
        background: var(--line-strong);
      }
      .lvl[data-l="expert"] i {
        background: var(--mint);
      }
      .lvl[data-l="advanced"] i:nth-child(-n + 2) {
        background: var(--violet);
      }
      .lvl[data-l="intermediate"] i:nth-child(1) {
        background: var(--amber);
      }
      .lvl-legend {
        display: flex;
        gap: 22px;
        margin-top: 22px;
        font-family: var(--mono);
        font-size: 11.5px;
        color: var(--dim);
      }
      .lvl-legend span {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      /* ===================== EXPERIENCE ===================== */
      .xp {
        display: grid;
        gap: 16px;
      }
      .xp-item {
        display: grid;
        grid-template-columns: 190px 1fr;
        gap: 28px;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 30px;
        transition: border-color 0.25s var(--ease);
      }
      .xp-item:hover {
        border-color: var(--line-strong);
      }
      .xp-when {
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--amber);
        line-height: 1.9;
      }
      .xp-when .loc {
        display: block;
        color: var(--dim);
      }
      .xp-when .now {
        display: inline-block;
        margin-top: 6px;
        color: var(--mint);
        border: 1px solid rgba(111, 227, 190, 0.35);
        border-radius: 999px;
        padding: 2px 10px;
        font-size: 11px;
        background: var(--mint-soft);
      }
      .xp-body h3 {
        font-family: var(--display);
        font-weight: 700;
        font-size: 22px;
        letter-spacing: -0.01em;
      }
      .xp-body .co {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--violet);
        margin: 3px 0 12px;
      }
      .xp-body .co a {
        color: inherit;
      }
      .xp-body .desc {
        color: var(--fog);
        font-size: 15px;
        margin-bottom: 14px;
      }
      .xp-body ul {
        list-style: none;
        display: grid;
        gap: 9px;
        margin-bottom: 18px;
      }
      .xp-body li {
        position: relative;
        padding-left: 20px;
        color: var(--paper);
        font-size: 14.5px;
      }
      .xp-body li::before {
        content: "→";
        position: absolute;
        left: 0;
        color: var(--mint);
        font-family: var(--mono);
        font-size: 12px;
        top: 2px;
      }
      .stack {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
      }
      .stack span {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--fog);
        background: var(--panel-2);
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 3px 9px;
      }
      @media (max-width: 720px) {
        .xp-item {
          grid-template-columns: 1fr;
          gap: 14px;
          padding: 24px;
        }
      }

      /* ===================== PROJECTS ===================== */
      .proj-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }
      .proj {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        position: relative;
        overflow: hidden;
        transition:
          border-color 0.25s var(--ease),
          transform 0.25s var(--ease);
      }
      .proj:hover {
        transform: translateY(-4px);
        border-color: rgba(111, 227, 190, 0.4);
      }
      .proj.full {
        grid-column: 1/-1;
      }
      .proj-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 14px;
      }
      .proj h3 {
        font-family: var(--display);
        font-weight: 700;
        font-size: 26px;
        letter-spacing: -0.015em;
      }
      .proj .year {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--dim);
      }
      .proj .tag {
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--violet);
      }
      .proj p {
        color: var(--fog);
        font-size: 15px;
        max-width: 640px;
      }
      .proj-high {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 8px 22px;
        font-family: var(--mono);
        font-size: 12.5px;
        color: var(--amber);
      }
      .proj-high li::before {
        content: "◆ ";
        font-size: 9px;
        vertical-align: 2px;
      }
      .proj-foot {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: auto;
      }
      .proj-links {
        display: flex;
        gap: 18px;
        font-family: var(--mono);
        font-size: 13px;
      }
      @media (max-width: 720px) {
        .proj-grid {
          grid-template-columns: 1fr;
        }
      }

      /* ========== LOG — talks · publications · certs · awards ========== */
      .log {
        border: 1px solid var(--line);
        border-radius: 14px;
        overflow: hidden;
      }
      .log-row {
        display: grid;
        grid-template-columns: 96px 110px 1fr auto;
        gap: 20px;
        align-items: baseline;
        padding: 18px 24px;
        border-bottom: 1px solid var(--line);
        background: var(--panel);
        transition: background 0.2s var(--ease);
      }
      .log-row:last-child {
        border-bottom: none;
      }
      .log-row:hover {
        background: var(--panel-2);
      }
      .log-date {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--amber);
      }
      .log-type {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .log-type.talk {
        color: var(--mint);
      }
      .log-type.article {
        color: var(--violet);
      }
      .log-type.cert {
        color: var(--fog);
      }
      .log-type.award {
        color: var(--amber);
      }
      .log-title {
        font-size: 15px;
        color: var(--paper);
      }
      .log-title small {
        display: block;
        color: var(--dim);
        font-size: 13px;
      }
      .log-links {
        font-family: var(--mono);
        font-size: 12.5px;
        display: flex;
        gap: 14px;
      }
      @media (max-width: 720px) {
        .log-row {
          grid-template-columns: 1fr;
          gap: 5px;
          padding: 16px 20px;
        }
      }

      /* ===================== TESTIMONIALS ===================== */
      .quotes {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }
      .quote {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 30px;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .quote blockquote {
        font-family: var(--display);
        font-weight: 600;
        font-size: 19px;
        line-height: 1.5;
        letter-spacing: -0.01em;
      }
      .quote blockquote::before {
        content: "\201C";
        color: var(--violet);
        margin-right: 2px;
      }
      .quote blockquote::after {
        content: "\201D";
        color: var(--violet);
      }
      .quote-who {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: auto;
      }
      .avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        flex-shrink: 0;
        overflow: hidden;
        display: grid;
        place-items: center;
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
      }
      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .avatar.a1 {
        background: linear-gradient(135deg, var(--mint), var(--violet));
      }
      .avatar.a2 {
        background: linear-gradient(135deg, var(--amber), var(--violet));
      }
      .quote-who b {
        display: block;
        font-size: 14.5px;
        font-weight: 600;
      }
      .quote-who span {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--dim);
      }
      @media (max-width: 720px) {
        .quotes {
          grid-template-columns: 1fr;
        }
      }

      /* ===================== ABOUT EXTRAS ===================== */
      .extras {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }
      .extra {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 26px;
      }
      .extra.span {
        grid-column: 1/-1;
      }
      .extra h3 {
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 600;
        color: var(--amber);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 16px;
      }
      .extra ul {
        list-style: none;
        display: grid;
        gap: 10px;
        font-size: 14.5px;
      }
      .extra .prof {
        font-family: var(--mono);
        font-size: 11.5px;
        color: var(--dim);
      }
      .extra p {
        color: var(--fog);
        font-size: 14px;
      }
      .extra p b {
        color: var(--paper);
      }
      .extra .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      @media (max-width: 840px) {
        .extras {
          grid-template-columns: 1fr;
        }
      }

      /* ===================== CONTACT / FOOTER ===================== */
      .contact {
        padding: 96px 0 60px;
        text-align: left;
      }
      .contact h2 {
        font-family: var(--display);
        font-weight: 800;
        letter-spacing: -0.025em;
        font-size: clamp(40px, 7vw, 80px);
        line-height: 1.02;
        margin: 8px 0 22px;
      }
      .contact h2 a {
        color: var(--paper);
        background: linear-gradient(90deg, var(--mint), var(--violet));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .contact h2 a:hover {
        text-decoration: none;
        filter: brightness(1.15);
      }
      .contact p {
        color: var(--fog);
        max-width: 520px;
        margin-bottom: 30px;
      }
      .socials {
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
        font-family: var(--mono);
        font-size: 13px;
      }
      footer.site {
        border-top: 1px solid var(--line);
        padding: 26px 0;
        margin-top: 40px;
      }
      footer.site .wrap {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        font-family: var(--mono);
        font-size: 12px;
        color: var(--dim);
      }
      footer.site .k {
        color: var(--violet);
      }
      footer.site .s {
        color: var(--mint);
      }

      /* ========== SOURCE OVERLAY — the signature ========== */
      .src-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        background: var(--ink);
        display: none;
        flex-direction: column;
      }
      .src-overlay.open {
        display: flex;
      }
      .src-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 14px 24px;
        border-bottom: 1px solid var(--line);
        flex-shrink: 0;
        font-family: var(--mono);
        font-size: 13px;
      }
      .src-bar .path {
        color: var(--fog);
      }
      .src-bar .path .f {
        color: var(--mint);
      }
      .src-actions {
        display: flex;
        gap: 10px;
      }
      .mini-btn {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--fog);
        background: var(--panel);
        border: 1px solid var(--line-strong);
        border-radius: 7px;
        padding: 6px 13px;
        cursor: pointer;
        transition:
          color 0.2s,
          border-color 0.2s;
      }
      .mini-btn:hover {
        color: var(--paper);
        border-color: var(--violet);
      }
      .src-scroll {
        overflow: auto;
        flex: 1;
        padding: 26px 0 60px;
      }
      .src-code {
        font-family: var(--mono);
        font-size: 13px;
        line-height: 1.75;
        max-width: 920px;
        margin: 0 auto;
        padding: 0 28px;
        white-space: pre;
        tab-size: 2;
      }
      .src-code .ln {
        display: inline-block;
        width: 44px;
        color: var(--dim);
        opacity: 0.55;
        user-select: none;
        text-align: right;
        padding-right: 20px;
      }
      .src-code .jk {
        color: var(--violet);
      }
      .src-code .js {
        color: var(--mint);
      }
      .src-code .jn {
        color: var(--amber);
      }
      .src-code .jb {
        color: #ff8fb2;
      }
      .src-code .jp {
        color: var(--fog);
      }

      /* scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.7s var(--ease),
          transform 0.7s var(--ease);
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </head>
  <body>

    <header class="site">
      <div class="wrap nav">
        <a class="brand" href="#top"><span class="v">{{lower personal.firstName}}</span>.<span class="m">{{lower personal.lastName}}</span></a>
        <ul class="nav-links">
          <li><a href="#skills">skills</a></li>
          <li><a href="#experience">experience</a></li>
          <li><a href="#projects">projects</a></li>
          <li><a href="#log">log</a></li>
          <li><a href="#contact">contact</a></li>
        </ul>
        <button class="src-btn" id="srcToggle" aria-haspopup="dialog" aria-controls="srcOverlay">{ } view source <kbd>.</kbd></button>
      </div>
    </header>

    <main id="top">

      {{! HERO ← personal, meta }}
      <section class="hero wrap">
        <p class="hero-path">~/{{lower personal.firstName}}-{{lower personal.lastName}}/profile.json <span>·</span> <span class="ver">v{{meta.version}}</span> <span>·</span> updated {{meta.lastUpdated}}</p>
        <h1>{{personal.displayName}}<span class="cursor" aria-hidden="true"></span></h1>
        <p class="headline">{{personal.headline}}.</p>
        <p class="bio">{{personal.bio}}</p>
        <div class="hero-meta">
          {{#if personal.location.remote}}<span class="chip live">open to remote</span>{{/if}}
          <span class="chip">{{personal.location.city}}, {{personal.location.state}}</span>
          <span class="chip">{{personal.title}}</span>
        </div>
        <div class="hero-cta">
          <a class="btn btn-primary" href="mailto:{{personal.contact.email}}">Email me →</a>
          {{#if personal.social.github}}<a class="btn btn-ghost" href="{{personal.social.github}}" target="_blank" rel="noopener">GitHub ↗</a>{{/if}}
        </div>
      </section>

      {{! SKILLS ← skills }}
      <section id="skills" class="wrap reveal">
        <div class="key-open"><span class="k">"skills"</span><span class="p">: [</span><span class="rule"></span><span class="count">{{skills.length}} categories</span></div>
        <h2 class="sec-title">What I work with</h2>
        <div class="skills-grid">
          {{#each skills}}
            <div class="skill-card">
              <h3>{{category}}</h3>
              <ul>
                {{#each items}}
                  <li>{{name}} <span class="lvl" data-l="{{level}}" title="{{level}}"><i></i><i></i><i></i></span></li>
                {{/each}}
              </ul>
            </div>
          {{/each}}
        </div>
        <div class="lvl-legend" aria-hidden="true">
          <span><span class="lvl" data-l="expert"><i></i><i></i><i></i></span> expert</span>
          <span><span class="lvl" data-l="advanced"><i></i><i></i><i></i></span> advanced</span>
          <span><span class="lvl" data-l="intermediate"><i></i><i></i><i></i></span> intermediate</span>
        </div>
        <div class="key-close">]</div>
      </section>

      {{! EXPERIENCE ← experience }}
      <section id="experience" class="wrap reveal">
        <div class="key-open"><span class="k">"experience"</span><span class="p">: [</span><span class="rule"></span><span class="count">{{experience.length}} roles</span></div>
        <h2 class="sec-title">Where I've shipped</h2>
        <div class="xp">
          {{#each experience}}
            <article class="xp-item">
              <div class="xp-when">
                {{dotDate startDate}}
                —
                {{#if current}}now{{else}}{{dotDate endDate}}{{/if}}
                <span class="loc">{{location}}</span>
                {{#if current}}<span class="now">current</span>{{/if}}
              </div>
              <div class="xp-body">
                <h3>{{role}}</h3>
                <p class="co">{{#if url}}<a href="{{url}}" target="_blank" rel="noopener">{{company}}</a>{{else}}{{company}}{{/if}}</p>
                <p class="desc">{{description}}</p>
                <ul>
                  {{#each highlights}}<li>{{this}}</li>{{/each}}
                </ul>
                <div class="stack">{{#each techStack}}<span>{{this}}</span>{{/each}}</div>
              </div>
            </article>
          {{/each}}
        </div>
        <div class="key-close">]</div>
      </section>

      {{! PROJECTS ← projects (first entry spans full width) }}
      <section id="projects" class="wrap reveal">
        <div class="key-open"><span class="k">"projects"</span><span class="p">: [</span><span class="rule"></span><span class="count">{{projects.length}} shipped</span></div>
        <h2 class="sec-title">Things I've built</h2>
        <div class="proj-grid">
          {{#each projects}}
            <article class="proj{{#if @first}} full{{/if}}">
              <div class="proj-top"><h3>{{name}}</h3><span class="year">{{year}}</span></div>
              <p class="tag">{{tagline}}</p>
              <p>{{description}}</p>
              <ul class="proj-high">
                {{#each highlights}}<li>{{this}}</li>{{/each}}
              </ul>
              <div class="proj-foot">
                <div class="stack">{{#each techStack}}<span>{{this}}</span>{{/each}}</div>
                <div class="proj-links">
                  {{#if liveUrl}}<a href="{{liveUrl}}" target="_blank" rel="noopener">live ↗</a>{{/if}}
                  {{#if repoUrl}}<a href="{{repoUrl}}" target="_blank" rel="noopener">repo ↗</a>{{/if}}
                </div>
              </div>
            </article>
          {{/each}}
        </div>
        <div class="key-close">]</div>
      </section>

      {{! LOG ← talks + publications + certifications + awards (merged in build.js) }}
      <section id="log" class="wrap reveal">
        <div class="key-open"><span class="k">"talks" + "publications" + "certifications" + "awards"</span><span class="p">: [</span><span class="rule"></span><span class="count">{{log.length}} entries</span></div>
        <h2 class="sec-title">Public record</h2>
        <div class="log">
          {{#each log}}
            <div class="log-row">
              <span class="log-date">{{dotDate date}}</span>
              <span class="log-type {{type}}">{{type}}</span>
              <span class="log-title">{{title}}<small>{{subtitle}}</small></span>
              <span class="log-links">
                {{#each links}}<a href="{{url}}" target="_blank" rel="noopener">{{label}}</a>{{/each}}
              </span>
            </div>
          {{/each}}
        </div>
        <div class="key-close">]</div>
      </section>

      {{! TESTIMONIALS ← testimonials }}
      {{#if testimonials.length}}
        <section id="testimonials" class="wrap reveal">
          <div class="key-open"><span class="k">"testimonials"</span><span class="p">: [</span><span class="rule"></span><span class="count">{{testimonials.length}}</span></div>
          <h2 class="sec-title">What teams say</h2>
          <div class="quotes">
            {{#each testimonials}}
              <div class="quote">
                <blockquote>{{quote}}</blockquote>
                <div class="quote-who">
                  <span class="avatar {{cycle @index 'a1' 'a2'}}" aria-hidden="true">{{#if photo}}<img src="{{photo}}" alt="" loading="lazy" />{{else}}{{initials author}}{{/if}}</span>
                  <div><b>{{author}}</b><span>{{role}} · {{company}}</span></div>
                </div>
              </div>
            {{/each}}
          </div>
          <div class="key-close">]</div>
        </section>
      {{/if}}

      {{! EXTRAS ← education, languages, volunteer, interests }}
      <section id="about" class="wrap reveal">
        <div class="key-open"><span class="k">"education" + "languages" + "volunteer" + "interests"</span><span class="p">: {</span><span class="rule"></span></div>
        <h2 class="sec-title">Beyond the stack</h2>
        <div class="extras">
          <div class="extra">
            <h3>Education</h3>
            <ul>
              {{#each education}}
                <li><b>{{institution}}</b>
                  —
                  {{degree}},
                  {{field}}<br />
                  <span class="prof">{{startDate}}–{{endDate}}{{#if gpa}} · GPA {{gpa}}{{/if}}{{#each honors}} · {{this}}{{/each}}</span>
                </li>
              {{/each}}
            </ul>
          </div>
          <div class="extra">
            <h3>Languages</h3>
            <ul>
              {{#each languages}}
                <li>{{language}} <span class="prof">— {{proficiency}}</span></li>
              {{/each}}
            </ul>
          </div>
          <div class="extra">
            <h3>Volunteer</h3>
            {{#each volunteer}}
              <p><b>{{organization}}</b> — {{description}} <span class="prof">{{dotDate startDate}} — {{#if current}}now{{else}}{{dotDate endDate}}{{/if}}</span></p>
            {{/each}}
          </div>
          <div class="extra span">
            <h3>Interests</h3>
            <div class="chips">
              {{#each interests}}<span class="chip">{{this}}</span>{{/each}}
            </div>
          </div>
        </div>
        <div class="key-close">}</div>
      </section>

      {{! CONTACT ← personal.contact, personal.social }}
      <section id="contact" class="wrap contact reveal">
        <div class="key-open"><span class="k">"contact"</span><span class="p">: {</span><span class="rule"></span></div>
        <h2>Let's build something.<br /><a href="mailto:{{personal.contact.email}}">{{personal.contact.email}}</a></h2>
        <p>{{summary}}</p>
        <div class="socials">
          {{#each personal.social}}{{#if this}}<a href="{{this}}" target="_blank" rel="noopener">{{@key}} ↗</a>{{/if}}{{/each}}
          {{#if personal.contact.phone}}<a href="tel:{{tel personal.contact.phone}}">{{personal.contact.phone}}</a>{{/if}}
        </div>
        <div class="key-close">}</div>
      </section>

    </main>

    <footer class="site">
      <div class="wrap">
        <span><span class="k">"builtWith"</span>: <span class="s">"handlebars + profile.json"</span></span>
        <span>© {{year}} {{personal.displayName}} · rendered from profile.json</span>
      </div>
    </footer>

    {{! SOURCE OVERLAY — the signature: same palette, raw data }}
    <div class="src-overlay" id="srcOverlay" role="dialog" aria-modal="true" aria-label="View profile.json source">
      <div class="src-bar">
        <span class="path">~/{{lower personal.firstName}}-{{lower personal.lastName}}/<span class="f">profile.json</span> — this entire page, as data</span>
        <div class="src-actions">
          <button class="mini-btn" id="copyJson">copy json</button>
          <button class="mini-btn" id="srcClose">esc · close</button>
        </div>
      </div>
      <div class="src-scroll"><pre class="src-code" id="srcCode"></pre></div>
    </div>

    {{! The exact render context, embedded — the overlay reads from here }}
    <script type="application/json" id="profileData">{{{json this}}}</script>

    <script>
      /* ---------- source overlay ---------- */
      const PROFILE = JSON.parse(document.getElementById("profileData").textContent);
      delete PROFILE.log;
      /* computed at build time, not part of profile.json */
      const overlay = document.getElementById("srcOverlay");
      const codeEl = document.getElementById("srcCode");
      const toggle = document.getElementById("srcToggle");
      let rendered = false;
      function esc(s) {
        return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
      }
      function highlightJSON(json) {
        return esc(json).replace(/("(\\u[a-fA-F0-9]{4}|\\[^u]|[^\\"])*")(\s*:)?|\b(true|false|null)\b|-?\d+(\.\d+)?([eE][+-]?\d+)?/g, (m) => {
          let cls = "jn";
          if (/^"/.test(m)) {
            cls = /:$/.test(m) ? "jk" : "js";
          } else if (/true|false|null/.test(m)) {
            cls = "jb";
          }
          if (cls === "jk") {
            return '<span class="jk">' + m.replace(/:\s*$/, "") + '</span><span class="jp">:</span>';
          }
          return '<span class="' + cls + '">' + m + "</span>";
        });
      }
      function renderSource() {
        const raw = JSON.stringify(PROFILE, null, 2);
        const lines = highlightJSON(raw).split("\n");
        codeEl.innerHTML = lines.map((l, i) => '<span class="ln">' + (i + 1) + "</span>" + l).join("\n");
        rendered = true;
      }
      function openSrc() {
        if (!rendered) renderSource();
        overlay.classList.add("open");
        document.body.style.overflow = "hidden";
        document.getElementById("srcClose").focus();
      }
      function closeSrc() {
        overlay.classList.remove("open");
        document.body.style.overflow = "";
        toggle.focus();
      }
      toggle.addEventListener("click", openSrc);
      document.getElementById("srcClose").addEventListener("click", closeSrc);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && overlay.classList.contains("open")) closeSrc();
        if (e.key === "." && !overlay.classList.contains("open") && !/input|textarea/i.test(document.activeElement.tagName)) openSrc();
      });
      document.getElementById("copyJson").addEventListener("click", function () {
        navigator.clipboard.writeText(JSON.stringify(PROFILE, null, 2)).then(() => {
          this.textContent = "copied ✓";
          setTimeout(() => (this.textContent = "copy json"), 1600);
        });
      });
      /* ---------- scroll reveal ---------- */ if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) {
                en.target.classList.add("in");
                io.unobserve(en.target);
              }
            });
          },
          { threshold: 0.08 }
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("in"));
      }
    </script>
  </body>
</html>