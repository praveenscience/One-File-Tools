<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{displayName}} — Portfolio</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: #e4e4e7;
  background: #09090b;
}

a { color: #60a5fa; text-decoration: none; }
a:hover { text-decoration: underline; }

.container { max-width: 960px; margin: 0 auto; padding: 0 24px; }

/* Hero */
.hero {
  padding: 80px 0 60px;
  text-align: center;
  border-bottom: 1px solid #27272a;
}
.hero-photo {
  width: 120px; height: 120px; border-radius: 50%;
  object-fit: cover; border: 3px solid #3b82f6;
  margin-bottom: 20px;
}
.hero h1 { font-size: 2.5rem; font-weight: 700; color: #fafafa; margin-bottom: 4px; }
.hero .title { font-size: 1.1rem; color: #3b82f6; font-weight: 500; margin-bottom: 12px; }
.hero .bio { max-width: 600px; margin: 0 auto 20px; color: #a1a1aa; font-size: 0.95rem; }
.hero-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.hero-links a {
  font-size: 0.85rem; padding: 6px 16px; border-radius: 6px;
  border: 1px solid #27272a; color: #a1a1aa; transition: all 0.2s;
}
.hero-links a:hover { border-color: #3b82f6; color: #60a5fa; text-decoration: none; }

/* Section */
section { padding: 48px 0; border-bottom: 1px solid #27272a; }
section:last-child { border-bottom: none; }
h2 {
  font-size: 1.5rem; font-weight: 700; color: #fafafa;
  margin-bottom: 24px; letter-spacing: -0.02em;
}
h2 span { color: #3b82f6; }

/* Project cards */
.projects-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
.project-card {
  border: 1px solid #27272a; border-radius: 12px; padding: 24px;
  background: #18181b; transition: border-color 0.2s;
}
.project-card:hover { border-color: #3b82f6; }
.project-card h3 { font-size: 1.15rem; color: #fafafa; margin-bottom: 4px; }
.project-card .tagline { font-size: 0.85rem; color: #3b82f6; margin-bottom: 10px; }
.project-card p { font-size: 0.9rem; color: #a1a1aa; margin-bottom: 12px; }
.project-card .tech {
  display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px;
}
.project-card .tech span {
  font-size: 0.75rem; padding: 3px 8px; border-radius: 4px;
  background: #27272a; color: #a1a1aa;
}
.project-card .highlights { list-style: none; padding: 0; margin-bottom: 12px; }
.project-card .highlights li {
  font-size: 0.85rem; color: #a1a1aa; padding-left: 16px; position: relative; margin-bottom: 4px;
}
.project-card .highlights li::before { content: "->"; position: absolute; left: 0; color: #3b82f6; }
.project-card .links { display: flex; gap: 12px; }
.project-card .links a {
  font-size: 0.8rem; color: #60a5fa; padding: 4px 10px;
  border: 1px solid #27272a; border-radius: 4px;
}
.project-card .links a:hover { border-color: #3b82f6; text-decoration: none; }

/* Skills */
.skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
.skill-group { border: 1px solid #27272a; border-radius: 10px; padding: 20px; background: #18181b; }
.skill-group h3 { font-size: 0.9rem; color: #3b82f6; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
.skill-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.skill-item .name { font-size: 0.85rem; color: #e4e4e7; }
.skill-item .level { font-size: 0.7rem; color: #71717a; text-transform: capitalize; }

/* Experience timeline */
.timeline { position: relative; padding-left: 24px; }
.timeline::before { content: ""; position: absolute; left: 4px; top: 8px; bottom: 8px; width: 1px; background: #27272a; }
.timeline-item { position: relative; margin-bottom: 28px; }
.timeline-item::before {
  content: ""; position: absolute; left: -24px; top: 8px;
  width: 9px; height: 9px; border-radius: 50%;
  background: #3b82f6; border: 2px solid #09090b;
}
.timeline-item h3 { font-size: 1rem; color: #fafafa; }
.timeline-item .meta { font-size: 0.85rem; color: #71717a; margin-bottom: 6px; }
.timeline-item p { font-size: 0.9rem; color: #a1a1aa; }

/* Talks */
.talks-list { display: grid; gap: 12px; }
.talk-item { padding: 16px; border: 1px solid #27272a; border-radius: 8px; background: #18181b; }
.talk-item h3 { font-size: 0.95rem; color: #fafafa; margin-bottom: 4px; }
.talk-item .meta { font-size: 0.8rem; color: #71717a; margin-bottom: 8px; }
.talk-item .talk-links { display: flex; gap: 10px; }
.talk-item .talk-links a { font-size: 0.8rem; }

/* Testimonials */
.testimonials-grid { display: grid; gap: 16px; }
.testimonial-card { padding: 20px; border: 1px solid #27272a; border-radius: 10px; background: #18181b; }
.testimonial-card blockquote { font-size: 0.9rem; color: #a1a1aa; font-style: italic; margin-bottom: 12px; line-height: 1.7; }
.testimonial-card cite { font-size: 0.8rem; color: #71717a; font-style: normal; }
.testimonial-card cite strong { color: #e4e4e7; }

/* Publications */
.pub-list { display: grid; gap: 10px; }
.pub-item { padding: 14px; border: 1px solid #27272a; border-radius: 8px; background: #18181b; }
.pub-item a { font-size: 0.95rem; color: #fafafa; font-weight: 500; }
.pub-item a:hover { color: #60a5fa; }
.pub-item .meta { font-size: 0.8rem; color: #71717a; margin-top: 4px; }

/* Awards, Certs */
.list-cards { display: grid; gap: 12px; }
.list-card { padding: 16px; border: 1px solid #27272a; border-radius: 8px; background: #18181b; }
.list-card h3 { font-size: 0.95rem; color: #fafafa; margin-bottom: 4px; }
.list-card .meta { font-size: 0.8rem; color: #71717a; }
.list-card p { font-size: 0.85rem; color: #a1a1aa; margin-top: 6px; }

/* Tags (interests, languages) */
.tag-row { display: flex; gap: 8px; flex-wrap: wrap; }
.tag {
  font-size: 0.8rem; padding: 5px 14px; border-radius: 999px;
  border: 1px solid #27272a; color: #a1a1aa;
}

/* Footer */
footer { padding: 40px 0; text-align: center; font-size: 0.8rem; color: #52525b; }
footer a { color: #60a5fa; }

/* Responsive */
@media (min-width: 640px) {
  .projects-grid { grid-template-columns: repeat(2, 1fr); }
  .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<div class="container">

<div class="hero">
  {{#photo}}<img class="hero-photo" src="{{photo}}" alt="{{displayName}}">{{/photo}}
  <h1>{{displayName}}</h1>
  {{#title}}<div class="title">{{title}}</div>{{/title}}
  {{#bio}}<p class="bio">{{bio}}</p>{{/bio}}
  <div class="hero-links">
    {{#email}}<a href="mailto:{{email}}">Email</a>{{/email}}
    {{#website}}<a href="{{website}}">{{stripProtocol website}}</a>{{/website}}
    {{#socialLinks}}<a href="{{url}}">{{label}}</a>{{/socialLinks}}
    {{#locationStr}}<span style="font-size:0.85rem;color:#71717a;padding:6px 0">{{locationStr}}</span>{{/locationStr}}
  </div>
</div>

{{#has projects}}
<section>
  <h2><span>//</span> Projects</h2>
  <div class="projects-grid">
    {{#projects}}
    <div class="project-card">
      <h3>{{name}}</h3>
      {{#tagline}}<div class="tagline">{{tagline}}</div>{{/tagline}}
      {{#description}}<p>{{description}}</p>{{/description}}
      {{#has techStack}}
      <div class="tech">
        {{#techStack}}<span>{{.}}</span>{{/techStack}}
      </div>
      {{/has}}
      {{#has highlights}}
      <ul class="highlights">
        {{#highlights}}<li>{{.}}</li>{{/highlights}}
      </ul>
      {{/has}}
      <div class="links">
        {{#liveUrl}}<a href="{{liveUrl}}">Live</a>{{/liveUrl}}
        {{#repoUrl}}<a href="{{repoUrl}}">Source</a>{{/repoUrl}}
      </div>
    </div>
    {{/projects}}
  </div>
</section>
{{/has}}

{{#has skills}}
<section>
  <h2><span>//</span> Skills</h2>
  <div class="skills-grid">
    {{#skills}}
    <div class="skill-group">
      <h3>{{category}}</h3>
      {{#items}}
      <div class="skill-item">
        <span class="name">{{name}}</span>
        <span class="level">{{level}}</span>
      </div>
      {{/items}}
    </div>
    {{/skills}}
  </div>
</section>
{{/has}}

{{#has experience}}
<section>
  <h2><span>//</span> Experience</h2>
  <div class="timeline">
    {{#experience}}
    <div class="timeline-item">
      <h3>{{role}}</h3>
      <div class="meta">{{company}} &middot; {{fmtDate startDate}} — {{fmtDate endDate}}{{#location}} &middot; {{location}}{{/location}}</div>
      {{#description}}<p>{{description}}</p>{{/description}}
    </div>
    {{/experience}}
  </div>
</section>
{{/has}}

{{#has talks}}
<section>
  <h2><span>//</span> Talks</h2>
  <div class="talks-list">
    {{#talks}}
    <div class="talk-item">
      <h3>{{title}}</h3>
      <div class="meta">{{event}} &middot; {{fmtDate date}}{{#location}} &middot; {{location}}{{/location}}</div>
      <div class="talk-links">
        {{#slidesUrl}}<a href="{{slidesUrl}}">Slides</a>{{/slidesUrl}}
        {{#videoUrl}}<a href="{{videoUrl}}">Video</a>{{/videoUrl}}
      </div>
    </div>
    {{/talks}}
  </div>
</section>
{{/has}}

{{#has publications}}
<section>
  <h2><span>//</span> Publications</h2>
  <div class="pub-list">
    {{#publications}}
    <div class="pub-item">
      {{#url}}<a href="{{url}}">{{title}}</a>{{/url}}
      {{^url}}<span style="font-size:0.95rem;color:#fafafa;font-weight:500">{{title}}</span>{{/url}}
      <div class="meta">{{publisher}} &middot; {{fmtDate date}}</div>
    </div>
    {{/publications}}
  </div>
</section>
{{/has}}

{{#has testimonials}}
<section>
  <h2><span>//</span> Testimonials</h2>
  <div class="testimonials-grid">
    {{#testimonials}}
    <div class="testimonial-card">
      <blockquote>"{{quote}}"</blockquote>
      <cite><strong>{{author}}</strong>{{#if role}}, {{role}}{{/if}}{{#if company}} at {{company}}{{/if}}</cite>
    </div>
    {{/testimonials}}
  </div>
</section>
{{/has}}

{{#has certifications}}
<section>
  <h2><span>//</span> Certifications</h2>
  <div class="list-cards">
    {{#certifications}}
    <div class="list-card">
      <h3>{{name}}</h3>
      <div class="meta">{{issuer}} &middot; {{fmtDate date}}</div>
    </div>
    {{/certifications}}
  </div>
</section>
{{/has}}

{{#has awards}}
<section>
  <h2><span>//</span> Awards</h2>
  <div class="list-cards">
    {{#awards}}
    <div class="list-card">
      <h3>{{title}}</h3>
      <div class="meta">{{issuer}} &middot; {{fmtDate date}}</div>
      {{#description}}<p>{{description}}</p>{{/description}}
    </div>
    {{/awards}}
  </div>
</section>
{{/has}}

{{#has education}}
<section>
  <h2><span>//</span> Education</h2>
  <div class="list-cards">
    {{#education}}
    <div class="list-card">
      <h3>{{degree}}{{#field}} in {{field}}{{/field}}</h3>
      <div class="meta">{{institution}} &middot; {{fmtDate startDate}} — {{fmtDate endDate}}{{#gpa}} &middot; GPA: {{gpa}}{{/gpa}}</div>
    </div>
    {{/education}}
  </div>
</section>
{{/has}}

{{#has languages}}
<section>
  <h2><span>//</span> Languages</h2>
  <div class="tag-row">
    {{#languages}}<span class="tag">{{language}} ({{proficiency}})</span>{{/languages}}
  </div>
</section>
{{/has}}

{{#has volunteer}}
<section>
  <h2><span>//</span> Volunteer</h2>
  <div class="list-cards">
    {{#volunteer}}
    <div class="list-card">
      <h3>{{role}}</h3>
      <div class="meta">{{organization}} &middot; {{fmtDate startDate}} — {{fmtDate endDate}}</div>
      {{#description}}<p>{{description}}</p>{{/description}}
    </div>
    {{/volunteer}}
  </div>
</section>
{{/has}}

{{#has interests}}
<section>
  <h2><span>//</span> Interests</h2>
  <div class="tag-row">
    {{#interests}}<span class="tag">{{.}}</span>{{/interests}}
  </div>
</section>
{{/has}}

</div>

<footer>
  <p>Built with <a href="{{toolsUrl}}">One File Tools</a></p>
</footer>

</body>
</html>
